/* =============================================
   EcoRoot - Automatic Impact Cycling Visualization
   Recreates removed detailed effects section as a compact auto-animated visual
   ============================================= */

class ImpactCycler {
  constructor() {
    this.canvas = document.getElementById('impactCanvas');
    this.ctx = this.canvas?.getContext('2d');
    this.iconEl = document.getElementById('impactCycleIcon');
    this.titleEl = document.getElementById('impactCycleTitle');
    this.listEl = document.getElementById('impactCycleList');
    this.barEl = document.getElementById('impactCycleBar');

    if (!this.canvas) {
      console.error('ImpactCycler: Canvas element not found!');
      return;
    }
    
    console.log('ImpactCycler initialized:', {
      canvas: this.canvas,
      width: this.canvas.width,
      height: this.canvas.height
    });

    this.duration = 5500; // ms per category
    this.fadeDuration = 500;
    this.index = 0;
    this.lastSwitch = performance.now();

    this.data = [
      {
        icon: '🌾',
        title: 'Effects on Plants & Crops',
        points: [
          'Poor or stunted growth',
          'Dull, unhealthy color',
          'Seed failure / early death',
          'Nutrient loss in topsoil',
          'Contaminated food products'
        ],
        colors: ['#4A7C59', '#2D5A3D'],
        visualize: 'plants'
      },
      {
        icon: '👤',
        title: 'Effects on Human Health',
        points: [
          'Skin & respiratory issues',
          'Food poisoning risks',
          'Children & farmers vulnerable',
          'Toxic exposure accumulation',
          'Long-term disease links'
        ],
        colors: ['#C23B22', '#E07B3C'],
        visualize: 'humans'
      },
      {
        icon: '🌍',
        title: 'Effects on Environment',
        points: [
          'Loss of fertility & biodiversity',
          'Ecosystem damage & collapse',
          'Water contamination spread',
          'Harmful gas/dust release',
          'Wildlife migration / die-off'
        ],
        colors: ['#2D5A3D', '#1E3D2A'],
        visualize: 'environment'
      }
    ];

    if (this.canvas) {
      this.resizeCanvas();
      window.addEventListener('resize', () => this.resizeCanvas());
      this.renderCategory(true);
      requestAnimationFrame((t) => this.loop(t));
    }
  }

  resizeCanvas() {
    const wrapper = this.canvas.parentElement;
    const width = wrapper.clientWidth;
    this.canvas.width = width;
    this.canvas.height = 400;
  }

  loop(timestamp) {
    const elapsed = timestamp - this.lastSwitch;
    // Update progress bar
    const progress = Math.min(elapsed / this.duration, 1);
    this.barEl.style.width = (progress * 100) + '%';

    if (elapsed >= this.duration) {
      this.index = (this.index + 1) % this.data.length;
      this.lastSwitch = timestamp;
      this.renderCategory();
    }

    this.drawBackground(progress);
    requestAnimationFrame((t) => this.loop(t));
  }

  renderCategory(initial = false) {
    const d = this.data[this.index];

    // Fade out then in
    if (!initial) {
      this.listEl.style.opacity = '0';
      this.titleEl.style.opacity = '0';
      this.iconEl.style.opacity = '0';
      setTimeout(() => {
        this.iconEl.textContent = d.icon;
        this.titleEl.textContent = d.title;
        this.listEl.innerHTML = d.points.map(p => `<li>${p}</li>`).join('');
        this.iconEl.style.opacity = '1';
        this.titleEl.style.opacity = '1';
        this.listEl.style.opacity = '1';
      }, this.fadeDuration);
    } else {
      this.iconEl.textContent = d.icon;
      this.titleEl.textContent = d.title;
      this.listEl.innerHTML = d.points.map(p => `<li>${p}</li>`).join('');
    }
  }

  drawBackground(progress) {
    const ctx = this.ctx;
    const d = this.data[this.index];
    ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

    // Gradient backdrop
    const grad = ctx.createLinearGradient(0, 0, this.canvas.width, this.canvas.height);
    grad.addColorStop(0, d.colors[0] + '22');
    grad.addColorStop(1, d.colors[1] + '11');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

    const centerX = this.canvas.width / 2;
    const centerY = this.canvas.height / 2;
    const time = performance.now();

    // Category-specific visualizations
    switch(d.visualize) {
      case 'plants':
        this.drawPlantsVisualization(ctx, centerX, centerY, time, d.colors, progress);
        break;
      case 'humans':
        this.drawHumansVisualization(ctx, centerX, centerY, time, d.colors, progress);
        break;
      case 'environment':
        this.drawEnvironmentVisualization(ctx, centerX, centerY, time, d.colors, progress);
        break;
    }
  }

  drawPlantsVisualization(ctx, centerX, centerY, time, colors, progress) {
    // Show contaminated soil affecting plants with detailed soil layers
    const soilY = centerY + 80;
    
    // Underground soil layers with depth
    const gradient = ctx.createLinearGradient(centerX, soilY - 20, centerX, soilY + 60);
    gradient.addColorStop(0, '#A0826D');
    gradient.addColorStop(0.3, '#8B4513');
    gradient.addColorStop(1, '#654321');
    ctx.fillStyle = gradient;
    ctx.fillRect(centerX - 140, soilY - 20, 280, 80);
    
    // Soil texture lines
    ctx.strokeStyle = '#654321' + '44';
    ctx.lineWidth = 1;
    for (let i = 0; i < 6; i++) {
      ctx.beginPath();
      ctx.moveTo(centerX - 140, soilY + i * 10);
      ctx.lineTo(centerX + 140, soilY + i * 10);
      ctx.stroke();
    }
    
    // Toxic chemical pools/patches in soil
    for (let i = 0; i < 4; i++) {
      const poolX = centerX - 100 + i * 60;
      const poolY = soilY + 20 + Math.sin(time / 800 + i) * 3;
      ctx.fillStyle = '#C23B22' + '88';
      ctx.beginPath();
      ctx.ellipse(poolX, poolY, 20, 8, 0, 0, Math.PI * 2);
      ctx.fill();
      
      // Bubbles rising from toxic pools
      const bubble = ((time / 1000 + i * 0.25) % 1);
      if (bubble < 0.8) {
        ctx.fillStyle = '#C23B22' + '66';
        ctx.beginPath();
        ctx.arc(poolX, poolY - bubble * 30, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    }
    
    // Animated toxic particles flowing through soil
    for (let i = 0; i < 25; i++) {
      const x = centerX - 120 + (i * 12) + Math.sin(time / 500 + i) * 4;
      const y = soilY + 5 + Math.cos(time / 600 + i * 2) * 8;
      const size = 2 + Math.sin(time / 400 + i) * 1;
      ctx.beginPath();
      ctx.fillStyle = i % 3 === 0 ? '#FF4444' : '#C23B22';
      ctx.arc(x, y, size, 0, Math.PI * 2);
      ctx.fill();
      
      // Glow effect on some particles
      if (i % 4 === 0) {
        ctx.fillStyle = '#FF4444' + '33';
        ctx.beginPath();
        ctx.arc(x, y, size * 2, 0, Math.PI * 2);
        ctx.fill();
      }
    }
    
    // Root systems absorbing toxins
    const plantCount = 6;
    for (let i = 0; i < plantCount; i++) {
      const x = centerX - 100 + (i * 40);
      const health = 1 - (i / plantCount) * 0.8; // Progressive decline
      
      // Root system
      ctx.strokeStyle = `rgba(139, 115, 85, ${health * 0.7})`;
      ctx.lineWidth = 2;
      for (let r = 0; r < 3; r++) {
        ctx.beginPath();
        ctx.moveTo(x, soilY);
        const rootX = x + (r - 1) * 15 + Math.sin(time / 1000 + r) * 2;
        const rootY = soilY + 20 + r * 5;
        ctx.quadraticCurveTo(x + (r - 1) * 8, soilY + 10, rootX, rootY);
        ctx.stroke();
      }
      
      // Plant stem with detail
      ctx.strokeStyle = health > 0.6 ? `rgba(74, 124, 89, ${health})` : `rgba(139, 115, 85, ${health})`;
      ctx.lineWidth = 4;
      ctx.beginPath();
      const stemHeight = 60 * health;
      const wobble = Math.sin(time / 1000 + i) * 2;
      ctx.moveTo(x, soilY);
      ctx.quadraticCurveTo(x + wobble, soilY - stemHeight / 2, x, soilY - stemHeight);
      ctx.stroke();
      
      // Multiple leaves at different heights
      const leafColor = health > 0.5 ? '#4A7C59' : (health > 0.3 ? '#8B7355' : '#A0826D');
      ctx.fillStyle = leafColor;
      for (let leaf = 0; leaf < 3; leaf++) {
        const leafY = soilY - stemHeight + leaf * 15;
        const leafHealth = health - leaf * 0.1;
        ctx.globalAlpha = Math.max(0.3, leafHealth);
        
        // Left leaf
        ctx.beginPath();
        ctx.ellipse(x - 12, leafY, 8 * health, 4 * health, -Math.PI / 6, 0, Math.PI * 2);
        ctx.fill();
        
        // Right leaf
        ctx.beginPath();
        ctx.ellipse(x + 12, leafY, 8 * health, 4 * health, Math.PI / 6, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      
      // Wilting/dead flowers on unhealthy plants
      if (health < 0.4) {
        ctx.font = '16px Arial';
        ctx.fillStyle = '#8B7355';
        ctx.globalAlpha = 0.6;
        ctx.fillText('✖', x - 6, soilY - stemHeight - 5);
        ctx.globalAlpha = 1;
      }
    }
    
    // Animated toxin absorption arrows (from roots to stems)
    ctx.strokeStyle = '#C23B22' + 'BB';
    ctx.lineWidth = 2;
    for (let i = 0; i < 8; i++) {
      const offset = (time / 800 + i * 0.3) % 1;
      const x = centerX - 80 + i * 30;
      const y = soilY + 15 - offset * 60;
      if (offset > 0.1 && offset < 0.9) {
        ctx.globalAlpha = Math.sin(offset * Math.PI) * 0.8;
        ctx.beginPath();
        ctx.moveTo(x, y);
        ctx.lineTo(x, y - 12);
        ctx.lineTo(x - 4, y - 7);
        ctx.moveTo(x, y - 12);
        ctx.lineTo(x + 4, y - 7);
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }
    
    // Label annotations
    ctx.font = 'bold 11px Arial';
    ctx.fillStyle = '#654321';
    ctx.fillText('Contaminated Soil', centerX - 140, soilY - 25);
    ctx.fillStyle = '#C23B22';
    ctx.fillText('Heavy Metals & Pesticides', centerX - 50, soilY + 55);
  }

  drawHumansVisualization(ctx, centerX, centerY, time, colors, progress) {
    // Show detailed contaminated crops → sick humans pathway
    
    // Farm field on left with rows
    const farmX = centerX - 110;
    const farmY = centerY + 20;
    
    // Soil/field background
    ctx.fillStyle = '#8B7355' + '66';
    ctx.fillRect(farmX - 45, farmY, 90, 50);
    
    // Multiple crop rows showing contamination
    for (let row = 0; row < 3; row++) {
      for (let col = 0; col < 3; col++) {
        const cropX = farmX - 30 + col * 25;
        const cropY = farmY + 15 + row * 15;
        const contamLevel = (row + col) / 5;
        
        // Plant
        ctx.font = '20px Arial';
        ctx.fillStyle = contamLevel > 0.5 ? '#8B7355' : '#4A7C59';
        ctx.globalAlpha = 0.7;
        ctx.fillText('🌾', cropX - 10, cropY);
        ctx.globalAlpha = 1;
        
        // Toxic dots on contaminated crops
        if (contamLevel > 0.4) {
          ctx.fillStyle = '#C23B22';
          for (let d = 0; d < 2; d++) {
            ctx.beginPath();
            ctx.arc(cropX + d * 6 - 3, cropY - 8, 2, 0, Math.PI * 2);
            ctx.fill();
          }
        }
      }
    }
    
    // Warning signs in field
    ctx.font = '22px Arial';
    ctx.fillText('⚠️', farmX - 50, farmY - 10);
    ctx.fillText('☠️', farmX + 35, farmY - 10);
    
    // Harvest basket showing contaminated produce
    const basketX = farmX + 50;
    const basketY = centerY - 20;
    ctx.strokeStyle = '#8B4513';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(basketX, basketY, 18, 0, Math.PI, true);
    ctx.lineTo(basketX - 18, basketY + 10);
    ctx.lineTo(basketX + 18, basketY + 10);
    ctx.stroke();
    
    // Contaminated produce in basket
    ctx.font = '16px Arial';
    ctx.fillText('🥬', basketX - 15, basketY - 2);
    ctx.fillText('🍎', basketX + 2, basketY - 2);
    
    // Toxic particles emanating from basket
    for (let i = 0; i < 5; i++) {
      const rise = ((time / 800 + i * 0.2) % 1);
      if (rise < 0.7) {
        ctx.fillStyle = '#C23B22';
        ctx.globalAlpha = 1 - rise;
        ctx.beginPath();
        ctx.arc(basketX - 10 + i * 5, basketY - 15 - rise * 25, 2, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }
    }
    
  drawEnvironmentVisualization(ctx, centerX, centerY, time, colors, progress) {
    // Show detailed environmental degradation cascade
    
    // Multi-layer contaminated ground with depth
    const soilY = centerY + 60;
    
    // Deep soil layers
    const soilGrad = ctx.createRadialGradient(centerX, soilY, 10, centerX, soilY, 100);
    soilGrad.addColorStop(0, '#8B4513');
    soilGrad.addColorStop(0.5, '#654321');
    soilGrad.addColorStop(1, '#3D2817');
    ctx.fillStyle = soilGrad;
    ctx.beginPath();
    ctx.ellipse(centerX, soilY, 100, 35, 0, 0, Math.PI * 2);
    ctx.fill();
    
    // Toxic contamination spreading outward (pulsing)
    const spread = 70 + Math.sin(time / 1000) * 15;
    const toxicGrad = ctx.createRadialGradient(centerX, soilY, 0, centerX, soilY, spread);
    toxicGrad.addColorStop(0, '#C23B22' + 'AA');
    toxicGrad.addColorStop(0.6, '#C23B22' + '44');
    toxicGrad.addColorStop(1, '#C23B22' + '00');
    ctx.fillStyle = toxicGrad;
    ctx.beginPath();
    ctx.ellipse(centerX, soilY, spread, spread * 0.4, 0, 0, Math.PI * 2);
    ctx.fill();
    
    // Contamination particles spreading
    for (let i = 0; i < 20; i++) {
      const angle = (i / 20) * Math.PI * 2;
      const dist = 40 + ((time / 2000 + i * 0.05) % 1) * 60;
      const x = centerX + Math.cos(angle) * dist;
      const y = soilY + Math.sin(angle) * dist * 0.3;
      const alpha = 1 - ((time / 2000 + i * 0.05) % 1);
      ctx.fillStyle = `rgba(194, 59, 34, ${alpha * 0.8})`;
      ctx.beginPath();
      ctx.arc(x, y, 3, 0, Math.PI * 2);
      ctx.fill();
    }
    
    // LEFT: Water contamination system
    const waterX = centerX - 95;
    const waterY = centerY - 10;
    
    // Water body (pond/stream)
    const waterGrad = ctx.createRadialGradient(waterX, waterY, 0, waterX, waterY, 45);
    waterGrad.addColorStop(0, '#6BB6D6');
    waterGrad.addColorStop(0.4, '#4A90A4');
    waterGrad.addColorStop(1, '#2D5A66');
    ctx.fillStyle = waterGrad;
    ctx.beginPath();
    ctx.ellipse(waterX, waterY, 45, 30, 0, 0, Math.PI * 2);
    ctx.fill();
    
    // Contamination seeping into water
    ctx.strokeStyle = '#C23B22' + '88';
    ctx.lineWidth = 2;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(centerX - 50, soilY - 10);
    ctx.quadraticCurveTo(centerX - 70, centerY + 20, waterX + 20, waterY);
    ctx.stroke();
    ctx.setLineDash([]);
    
    // Polluted water particles
    for (let i = 0; i < 12; i++) {
      const waveX = waterX - 30 + (i * 6);
      const waveY = waterY + Math.sin(time / 400 + i) * 3;
      ctx.fillStyle = i % 3 === 0 ? '#8B4513' : '#C23B22';
      ctx.globalAlpha = 0.7;
      ctx.beginPath();
      ctx.arc(waveX, waveY, 2.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.globalAlpha = 1;
    }
    
    // Contaminated water droplets falling/spreading
    for (let i = 0; i < 4; i++) {
      const dropPhase = ((time / 600 + i * 0.25) % 1);
      if (dropPhase < 0.8) {
        const dx = waterX - 15 + i * 10;
        const dy = waterY + 30 + dropPhase * 35;
        ctx.fillStyle = `rgba(74, 144, 164, ${1 - dropPhase})`;
        ctx.beginPath();
        ctx.arc(dx, dy, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    }
    
    // Water emoji
    ctx.font = '28px Arial';
    ctx.fillText('💧', waterX - 14, waterY + 10);
    
    // TOP: Wildlife impact zone
    const wildlifeY = centerY - 65;
    
    // Multiple animals showing distress
    const animals = [
      { emoji: '🦎', x: -25, health: 0.4 },
      { emoji: '🐛', x: 0, health: 0.3 },
      { emoji: '🐝', x: 25, health: 0.5 }
    ];
    
    animals.forEach((animal, idx) => {
      const ax = centerX + animal.x;
      
      // Sick/dying aura
      ctx.fillStyle = colors[0] + '22';
      ctx.beginPath();
      ctx.arc(ax, wildlifeY, 18, 0, Math.PI * 2);
      ctx.fill();
      
      // Animal
      ctx.font = '26px Arial';
      ctx.globalAlpha = animal.health + Math.sin(time / 500 + idx) * 0.2;
      ctx.fillText(animal.emoji, ax - 13, wildlifeY + 8);
      ctx.globalAlpha = 1;
      
      // Escape/flee arrows
      const fleePhase = ((time / 1800 + idx * 0.33) % 1);
      if (fleePhase < 0.7) {
        const arrowY = wildlifeY - 20 - fleePhase * 30;
        ctx.strokeStyle = colors[1];
        ctx.lineWidth = 2;
        ctx.globalAlpha = 1 - fleePhase;
        ctx.beginPath();
        ctx.moveTo(ax, arrowY);
        ctx.lineTo(ax, arrowY - 12);
        ctx.lineTo(ax - 4, arrowY - 7);
        ctx.moveTo(ax, arrowY - 12);
        ctx.lineTo(ax + 4, arrowY - 7);
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    });
    
    // Soil organisms dying (microorganisms)
    ctx.font = 'bold 10px Arial';
    ctx.fillStyle = '#C23B22';
    for (let i = 0; i < 6; i++) {
      const mx = centerX - 40 + i * 15;
      const my = soilY - 15 + Math.sin(time / 500 + i) * 2;
      ctx.globalAlpha = 0.4 + Math.sin(time / 800 + i) * 0.3;
      ctx.fillText('✖', mx, my);
    }
    ctx.globalAlpha = 1;
    
    // RIGHT: Dead/dying vegetation
    const plantPositions = [
      { x: 70, y: 10, emoji: '🥀', size: '28px' },
      { x: 90, y: 30, emoji: '🥀', size: '24px' },
      { x: 110, y: 20, emoji: '🍂', size: '22px' },
      { x: 85, y: 50, emoji: '🍂', size: '20px' }
    ];
    
    plantPositions.forEach((plant, idx) => {
      const px = centerX + plant.x;
      const py = centerY + plant.y;
      const wilt = Math.sin(time / 1000 + idx) * 0.15;
      
      ctx.font = plant.size + ' Arial';
      ctx.globalAlpha = 0.5 + wilt;
      ctx.fillText(plant.emoji, px - 12, py);
      ctx.globalAlpha = 1;
    });
    
    // Toxic gas/dust clouds rising
    const cloudData = [
      { x: 50, y: -50, size: 22 },
      { x: 70, y: -45, size: 18 },
      { x: 90, y: -55, size: 20 }
    ];
    
    cloudData.forEach((cloud, idx) => {
      const rise = ((time / 1500 + idx * 0.3) % 1);
      const cy = centerY + cloud.y - rise * 20;
      const cloudSize = cloud.size + Math.sin(time / 700 + idx) * 4;
      
      ctx.fillStyle = `rgba(45, 90, 61, ${(1 - rise) * 0.4})`;
      ctx.beginPath();
      ctx.arc(centerX + cloud.x, cy, cloudSize, 0, Math.PI * 2);
      ctx.arc(centerX + cloud.x + 15, cy - 5, cloudSize * 0.7, 0, Math.PI * 2);
      ctx.fill();
    });
    
    // Biodiversity loss indicator
    ctx.strokeStyle = '#C23B22';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(centerX - 110, centerY - 90);
    ctx.lineTo(centerX - 95, centerY - 85);
    ctx.lineTo(centerX - 80, centerY - 95);
    ctx.lineTo(centerX - 65, centerY - 80);
    ctx.lineTo(centerX - 50, centerY - 100);
    ctx.stroke();
    
    // Downward trend arrow
    ctx.fillStyle = '#C23B22';
    ctx.beginPath();
    ctx.moveTo(centerX - 50, centerY - 100);
    ctx.lineTo(centerX - 55, centerY - 95);
    ctx.lineTo(centerX - 45, centerY - 95);
    ctx.fill();
    
    // Labels with background
    ctx.font = 'bold 11px Arial';
    ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
    ctx.fillRect(waterX - 30, waterY - 50, 85, 14);
    ctx.fillRect(centerX + 40, centerY + 60, 90, 14);
    
    ctx.fillStyle = '#2D5A66';
    ctx.fillText('Water Pollution', waterX - 28, waterY - 40);
    ctx.fillStyle = '#654321';
    ctx.fillText('Ecosystem Collapse', centerX + 42, centerY + 70);
  } 
    // Multiple health symptoms orbiting
    const symptoms = [
      { icon: '🤒', label: 'Fever' },
      { icon: '😷', label: 'Illness' },
      { icon: '💊', label: 'Medicine' },
      { icon: '🌡️', label: 'Temp' },
      { icon: '🤮', label: 'Nausea' }
    ];
    
    symptoms.forEach((symptom, i) => {
      const angle = (time / 2500 + i * (Math.PI * 2 / symptoms.length)) % (Math.PI * 2);
      const radius = 55 + Math.sin(time / 1000 + i) * 5;
      const sx = humanX + Math.cos(angle) * radius;
      const sy = humanY + Math.sin(angle) * radius;
      
      ctx.font = '22px Arial';
      ctx.fillText(symptom.icon, sx - 11, sy + 11);
      
      // Small label
      ctx.font = 'bold 8px Arial';
      ctx.fillStyle = '#666';
      ctx.fillText(symptom.label, sx - 12, sy + 25);
    });
    
    // Health decline indicator
    ctx.strokeStyle = '#C23B22';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(humanX - 30, humanY - 55);
    ctx.lineTo(humanX - 20, humanY - 50);
    ctx.lineTo(humanX - 10, humanY - 58);
    ctx.lineTo(humanX, humanY - 48);
    ctx.lineTo(humanX + 10, humanY - 65);
    ctx.stroke();
    
    // Down arrow
    ctx.fillStyle = '#C23B22';
    ctx.beginPath();
    ctx.moveTo(humanX + 10, humanY - 65);
    ctx.lineTo(humanX + 5, humanY - 70);
    ctx.lineTo(humanX + 15, humanY - 70);
    ctx.fill();
    
    // Labels
    ctx.font = 'bold 10px Arial';
    ctx.fillStyle = '#654321';
    ctx.fillText('Contaminated Farm', farmX - 45, farmY - 20);
    ctx.fillStyle = '#C23B22';
    ctx.fillText('Health Impact', humanX - 25, humanY + 60);
  }
}

// Initialize
window.addEventListener('DOMContentLoaded', () => {
  new ImpactCycler();
});
